# Razorpay test keys (optional; use mock adapter if unset)
# RAZORPAY_API_KEY=rzp_test_xxxxx
# RAZORPAY_API_SECRET=yyyyy

# PostgreSQL (required). Default if unset: postgresql://localhost:5432/carbon
# Option A: Local Postgres — createdb carbon, then set DATABASE_URL with your credentials
# Option B: Docker — docker run -d --name carbon-pg -e POSTGRES_PASSWORD=carbon -e POSTGRES_DB=carbon -p 5433:5432 postgres:15
#   then: DATABASE_URL=postgresql://postgres:carbon@localhost:5433/carbon
# DATABASE_URL=postgresql://user:password@localhost:5432/carbon

# Scenarios directory (default: ./scenarios)
# CARBON_SCENARIOS_DIR=./scenarios
